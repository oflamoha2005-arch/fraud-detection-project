# Local environment variables for fraud detection app
# Replace values below with real credentials before running the app.

# SMTP configuration (Gmail example uses port 587 and requires authentication)
ALERT_SMTP_SERVER=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USERNAME= your_real_email@gmail.com
ALERT_SMTP_PASSWORD=your_app_password
# Email sender and recipient
ALERT_EMAIL_SENDER=your_real_email@gmail.com
ALERT_EMAIL=receiver_email@gmail.com

# Database URL (optional override)
# DATABASE_URL=postgresql+psycopg2://postgres:password@localhost/FRAUDE_DETECTION
